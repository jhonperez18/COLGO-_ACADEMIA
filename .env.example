# ============================================================================
# Variables de Entorno - Base de Datos MySQL
# 
# Copia este archivo como .env y ajusta los valores según tu configuración
# ============================================================================

# Configuración de Base de Datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=colgo_db

# Configuración del servidor (opcional)
NODE_ENV=development
PORT=3001

# Configuración de Azure (si usas Azure MySQL)
# Descomenta las siguientes líneas para Azure
# DB_HOST=colgo-db-server.mysql.database.azure.com
# DB_USER=dbadmin@colgo-db-server
# DB_PASSWORD=TuContraseñaSegura123!

# Configuración JWT (para autenticación)
JWT_SECRET=tu_clave_secreta_muy_segura_aqui

# CORS (ajusta según tu dominio)
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=DEBUG
