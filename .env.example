# ============================================================================
# Variables de Entorno - Base de Datos MySQL
# 
# Copia este archivo como .env y ajusta los valores según tu configuración
# ============================================================================

# Configuración de Base de Datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=colgo_db
DB_POOL_CONNECTION_LIMIT=25
DB_POOL_MAX_IDLE=15
DB_POOL_IDLE_TIMEOUT_MS=60000

# Configuración del servidor (opcional)
NODE_ENV=development
PORT=3001

# Configuración de Azure (si usas Azure MySQL)
# Descomenta las siguientes líneas para Azure
# DB_HOST=colgo-db-server.mysql.database.azure.com
# DB_USER=dbadmin@colgo-db-server
# DB_PASSWORD=TuContraseñaSegura123!

# Configuración JWT (para autenticación)
JWT_SECRET=tu_clave_secreta_muy_segura_aqui
JWT_EXPIRES_IN=7d

# URL del frontend (enlaces en correos de invitación)
FRONTEND_URL=http://localhost:5173

# CORS: orígenes del front (lista separada por coma). Incluye tu URL de Vercel, ej. https://project-bm9ko.vercel.app
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Logging
LOG_LEVEL=DEBUG

# Frontend Vite (en Vercel: mismas claves; redeploy tras cambiar). Este repo es Vite, NO Next.js: NEXT_PUBLIC_* no aplica salvo Supabase abajo.
VITE_API_URL=http://localhost:3001/api
# Supabase (opcional si usas cliente). Preferido: VITE_*. Si ya pusiste en Vercel NEXT_PUBLIC_SUPABASE_URL / ANON_KEY, el build las acepta como alias.
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# --- Correo (invitación al crear usuario en /api/usuarios) ---
# Error 535 = usuario/clave SMTP rechazados (no es el correo del alumno, es la cuenta que ENVÍA).
#
# Gmail: 2 pasos + contraseña de aplicación: https://myaccount.google.com/apppasswords
# Yahoo (@yahoo.es, etc.): seguridad de cuenta Yahoo → generar contraseña de aplicación.
#   Si SMTP_USER es Yahoo y NO defines SMTP_HOST, el servidor se elige solo (Yahoo, no Gmail).
#
SMTP_HOST=
SMTP_PORT=
SMTP_USER=tu_cuenta@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx
# Opcional: solo nombre para el remitente (la dirección sigue siendo SMTP_USER con Gmail)
SMTP_FROM_NAME=COLGO Academia
# Si no usas Gmail, puedes fijar remitente: SMTP_FROM=nombre@tudominio.com
#
# Alias aceptados: EMAIL_USER, EMAIL_PASSWORD, EMAIL_HOST, EMAIL_PORT, EMAIL_FROM
# Desactivar detección Gmail: SMTP_USE_GMAIL_SERVICE=false
#
# Por defecto el usuario se crea aunque falle el envío del correo (SMTP mal configurado no bloquea).
# Para exigir correo obligatorio y hacer rollback si falla: REQUIRE_EMAIL_ON_USER_CREATE=1


# Configuración de Seguridad
PASSWORD_MIN_LENGTH=8

